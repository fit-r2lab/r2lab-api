# PostgreSQL — connects as root, no password needed (trust auth)
# requirements:
# - a PostgreSQL server running locally
# - a root role with a r2lab database owned by root
# - access to - at least r2lab database - granted to root
# - e.g.
# host all      root      127.0.0.1/32     trust
# with this setting, no need for a password in the url below
R2LAB_DATABASE_URL=postgresql://root@localhost/r2lab

# JWT authentication — generate a strong random secret for production
# e.g.: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
R2LAB_JWT_SECRET=change-me-to-a-random-string

# JWT token lifetime in minutes (default: 1440 = 24 hours)
R2LAB_JWT_EXPIRE_MINUTES=1440

# Mail delivery: "smtp" for production, "console" to print emails to stdout (dev)
R2LAB_MAIL_MODE=smtp

# SMTP relay — local postfix/sendmail, no auth needed
R2LAB_SMTP_HOST=localhost
R2LAB_SMTP_PORT=25

# Sender address for outgoing emails
R2LAB_MAIL_FROM=noreply@r2lab.inria.fr

# Mailing list notified when a new registration is pending review
R2LAB_ADMIN_EMAIL=fit-r2lab-dev@inria.fr

# Public base URL used in email links (verification, password setup)
R2LAB_BASE_URL=https://r2lab.inria.fr
