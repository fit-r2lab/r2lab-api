[Unit]
Description=R2Lab API
After=network.target postgresql.service
Requires=postgresql.service

[Service]
Type=simple
WorkingDirectory=/root/r2lab-api
ExecStart=/root/r2lab-api/.venv/bin/uvicorn r2lab_api.app:app --host 0.0.0.0 --port 80
Restart=on-failure
RestartSec=5

# Environment
EnvironmentFile=/root/r2lab-api/.env

# Logging — stdout/stderr go to journal
StandardOutput=journal
StandardError=journal
SyslogIdentifier=r2lab-api

[Install]
WantedBy=multi-user.target
